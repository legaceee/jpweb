generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  PENDING
  CONTACTED
  QUOTED
  WON
  LOST
}

model Appointment {
  id            String     @id @default(uuid())
  fullName      String
  phone         String
  email         String
  address       String
  preferredDate DateTime
  preferredTime String     // e.g. "Morning", "Afternoon"
  service       String     // e.g. "Interior Design", "Civil Contracting"
  message       String?
  status        LeadStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model QuotationRequest {
  id             String     @id @default(uuid())
  fullName       String
  phone          String
  email          String
  service        String
  budget         String
  location       String
  projectDetails String
  status         LeadStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ContactForm {
  id        String   @id @default(uuid())
  fullName  String
  phone     String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
