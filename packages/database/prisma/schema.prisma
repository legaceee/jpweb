generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Appointment {
  id            String   @id @default(uuid())
  name          String
  phone         String
  serviceType   String
  preferredDate String
  message       String?
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
}

model Testimonial {
  id          String   @id @default(uuid())
  clientName  String
  area        String
  quote       String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}
